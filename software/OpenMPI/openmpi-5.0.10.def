Bootstrap: docker
From: ubuntu:24.04

%post
   # Only run the chmod command on CHTC HTC build nodes,
   # otherwise, delete or comment it out.
   chmod 777 /tmp

   # Install system packages
   export DEBIAN_FRONTEND=noninteractive
   apt-get -y update
   apt-get -y install git wget curl vim nano tar zip build-essential gcc cmake make zlib1g-dev

   # Install OpenMPI
   mkdir -p /opt/ompi
   wget https://download.open-mpi.org/release/open-mpi/v5.0/openmpi-5.0.10.tar.gz
   tar -xzvf openmpi-5.0.10.tar.gz
   cd openmpi-5.0.10
   ./configure --prefix=/opt/ompi
   make
   make install

%environment
    export OMPI_DIR=/opt/ompi
    export PATH="$OMPI_DIR/bin:$PATH"
    export LD_LIBRARY_PATH="$OMPI_DIR/lib:$LD_LIBRARY_PATH"
    export MANPATH="$OMPI_DIR/share/man:$MANPATH"
